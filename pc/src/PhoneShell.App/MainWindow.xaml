<Window x:Class="PhoneShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PhoneShell PC Client" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F6F8">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="PhoneShell PC Client" FontSize="22" FontWeight="SemiBold" />

        <Grid Grid.Row="1" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel -->
            <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="0">
                <DockPanel LastChildFill="True">
                    <!-- Server Settings Expander -->
                    <Expander DockPanel.Dock="Top" Header="Server Settings" IsExpanded="False" Padding="12,4">
                        <StackPanel Margin="0,4,0,8">
                            <CheckBox Content="Enable Relay Server (this PC as hub)"
                                      IsChecked="{Binding IsRelayServer}" Margin="0,0,0,6" />
                            <TextBlock Text="Port" FontWeight="SemiBold" />
                            <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,2,0,6" Width="100" HorizontalAlignment="Left" />
                            <TextBlock Text="Relay Server Address (when not hub)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding RelayServerAddress, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,2,0,6"
                                     IsEnabled="{Binding IsRelayServer, Converter={StaticResource InvertBoolConverter}}" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="Save" Width="80" Margin="0,0,8,0"
                                        Command="{Binding SaveServerSettingsCommand}" />
                                <Button Content="Start" Width="80" Margin="0,0,8,0"
                                        Command="{Binding StartNetworkCommand}"
                                        IsEnabled="{Binding IsServerStopped}"
                                        Background="#4CAF50" Foreground="White" FontWeight="SemiBold" />
                                <Button Content="Stop" Width="80" Margin="0,0,8,0"
                                        Command="{Binding StopNetworkCommand}"
                                        IsEnabled="{Binding IsServerRunning}"
                                        Background="#E53935" Foreground="White" FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="{Binding ServerStatus}" Margin="0,4,0,0"
                                       FontSize="11" Foreground="#666" TextWrapping="Wrap" />
                            <TextBlock Text="Reachable Address" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBox Text="{Binding RelayReachableAddresses, Mode=OneWay}"
                                     Margin="0,2,0,0"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="56"
                                     VerticalScrollBarVisibility="Auto" />
                        </StackPanel>
                    </Expander>

                    <!-- Shell Selector Expander -->
                    <Expander DockPanel.Dock="Top" Header="Shell" IsExpanded="False" Padding="12,4">
                        <StackPanel Margin="0,4,0,8">
                            <TextBlock Text="Select Terminal Shell" FontWeight="SemiBold" Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding AvailableShells}"
                                      SelectedItem="{Binding SelectedShell}"
                                      DisplayMemberPath="DisplayName"
                                      Margin="0,0,0,6" />
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button Content="Refresh" Width="80" Margin="0,0,8,0"
                                        Command="{Binding RefreshShellsCommand}" />
                                <Button Content="Restart Terminal" Width="110"
                                        Command="{Binding RestartTerminalCommand}" />
                            </StackPanel>
                            <TextBlock Text="Note: Changing shell requires restarting the terminal."
                                       FontSize="10" Foreground="#999" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Expander>

                    <!-- Device Info Expander -->
                    <Expander DockPanel.Dock="Top" Header="Device Info" IsExpanded="False" Padding="12,4">
                        <StackPanel Margin="0,4,0,8">
                            <TextBlock Text="ID" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding DeviceId}" TextWrapping="Wrap" />
                            <TextBlock Text="Status" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ConnectionStatus}" TextWrapping="Wrap" />
                            <TextBlock Text="Control Owner" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ControlOwnerText}" />
                            <TextBlock Text="Session Status" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SessionStatus}" TextWrapping="Wrap" FontSize="12" Foreground="#333333" />
                        </StackPanel>
                    </Expander>

                    <!-- QR Code Expander -->
                    <Expander DockPanel.Dock="Top" Header="QR Code" IsExpanded="False" Padding="12,4">
                        <StackPanel Margin="0,4,0,8">
                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="6" Padding="8" HorizontalAlignment="Left">
                                <Image Source="{Binding QrImage}" Width="200" Height="200" Stretch="Uniform" />
                            </Border>
                            <TextBlock Text="Payload" Margin="0,8,0,0" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding QrPayload}" TextWrapping="Wrap" FontSize="11" />
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Refresh QR" Width="100" Margin="0,0,8,0" Command="{Binding RefreshQrCommand}" />
                                <Button Content="Disconnect" Width="100" Command="{Binding ForceDisconnectCommand}" />
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- AI Settings Expander -->
                    <Expander DockPanel.Dock="Top" Header="AI Settings" IsExpanded="True" Padding="12,4">
                        <StackPanel Margin="0,4,0,8">
                            <TextBlock Text="API Endpoint" FontWeight="SemiBold" />
                            <TextBox Text="{Binding AiEndpoint, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />
                            <TextBlock Text="API Key" FontWeight="SemiBold" />
                            <PasswordBox x:Name="ApiKeyBox" PasswordChanged="ApiKeyBox_PasswordChanged" Margin="0,2,0,6" />
                            <TextBlock Text="Model" FontWeight="SemiBold" />
                            <TextBox Text="{Binding AiModelName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,6" />
                            <Button Content="Save" Width="80" HorizontalAlignment="Left" Command="{Binding SaveAiSettingsCommand}" />
                        </StackPanel>
                    </Expander>

                    <!-- Debug Log Expander -->
                    <Expander DockPanel.Dock="Top" Header="Debug Log" IsExpanded="False" Padding="12,4">
                        <ListBox ItemsSource="{Binding DebugLogs}" MaxHeight="400"
                                 BorderThickness="0" Background="#F9F9F9"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Mode=OneWay}" IsReadOnly="True"
                                             BorderThickness="1" BorderBrush="#E0E0E0"
                                             Background="#FFFFFF" Padding="6"
                                             TextWrapping="NoWrap" FontSize="10" FontFamily="Consolas"
                                             Margin="0,2"
                                             VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Auto"
                                             MaxHeight="300" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Expander>

                    <!-- AI Chat Area (fills remaining space) -->
                    <DockPanel Margin="12,8,12,12">
                        <TextBlock DockPanel.Dock="Top" Text="AI Chat" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6" />

                        <!-- Input area at bottom -->
                        <Grid DockPanel.Dock="Bottom" Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="ChatInputBox" Grid.Column="0"
                                     Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="ChatInput_KeyDown"
                                     IsEnabled="{Binding IsNotAutoExecuting}"
                                     VerticalContentAlignment="Center" Padding="6,4" />
                            <Button Grid.Column="1" Content="Send" Width="60" Margin="6,0,0,0"
                                    Command="{Binding SendMessageCommand}"
                                    IsEnabled="{Binding IsNotAutoExecuting}" />
                        </Grid>

                        <!-- Status panel -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                            <!-- Auto-exec status -->
                            <DockPanel Visibility="{Binding IsAutoExecuting, Converter={StaticResource BoolToVisConverter}}">
                                <Button DockPanel.Dock="Right" Content="Stop" Width="50"
                                        Command="{Binding StopAutoExecCommand}"
                                        Background="#E53935" Foreground="White" FontWeight="SemiBold"
                                        Padding="4,2" Margin="6,0,0,0" />
                                <TextBlock Text="{Binding AutoExecStatus}"
                                           FontSize="11" Foreground="#E53935" VerticalAlignment="Center" />
                            </DockPanel>
                            <!-- AI thinking (only when not auto-executing) -->
                            <TextBlock Text="AI is thinking..."
                                       FontSize="11" Foreground="#888"
                                       Visibility="{Binding IsAiLoading, Converter={StaticResource BoolToVisConverter}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAutoExecuting}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <!-- Chat messages list -->
                        <ListBox x:Name="ChatListBox" ItemsSource="{Binding ChatMessages}"
                                 BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0,2" />
                                    <Setter Property="Focusable" Value="False" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" CornerRadius="8" Margin="0,2" MaxWidth="300">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9" />
                                                <Setter Property="HorizontalAlignment" Value="Left" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                        <Setter Property="Background" Value="#E3F2FD" />
                                                        <Setter Property="HorizontalAlignment" Value="Right" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="12" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </DockPanel>
            </Border>

            <!-- Terminal -->
            <Border Grid.Column="2" Background="#0E1116" CornerRadius="10" Padding="0">
                <wv2:WebView2 x:Name="TerminalWebView" />
            </Border>
        </Grid>

        <TextBlock Grid.Row="2" Text="PhoneShell — PC client with relay server support" FontSize="12" Foreground="#666666" />
    </Grid>
</Window>
