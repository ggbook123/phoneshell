<Window x:Class="PhoneShell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PhoneShell" Height="780" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        MinWidth="900" MinHeight="550">

    <Window.Resources>
        <!-- Title bar button style -->
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Text3Brush}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface4Brush}" />
                                <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close button (red on hover) -->
        <Style x:Key="TitleBarCloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DangerBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab item style -->
        <Style x:Key="SessionTab" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface3Brush}" />
            <Setter Property="CornerRadius" Value="6,6,0,0" />
            <Setter Property="Padding" Value="12,6,6,6" />
            <Setter Property="Margin" Value="0,0,1,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource Surface4Brush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Text3Brush}" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        </Style>

        <!-- Field label -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="FontFamily" Value="{StaticResource BodyFont}" />
        </Style>

        <!-- Status indicator dot -->
        <Style x:Key="StatusDot" TargetType="Ellipse">
            <Setter Property="Width" Value="7" />
            <Setter Property="Height" Value="7" />
            <Setter Property="Fill" Value="{StaticResource Text3Brush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
    </Window.Resources>

    <!-- Outer border with shadow and rounded corners -->
    <Border Background="{StaticResource Surface1Brush}" CornerRadius="8"
            BorderBrush="{StaticResource Border1Brush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.5" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36" />  <!-- Custom title bar -->
                <RowDefinition Height="*" />   <!-- Content -->
                <RowDefinition Height="28" />  <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ============================================ -->
            <!-- CUSTOM TITLE BAR                             -->
            <!-- ============================================ -->
            <Border Grid.Row="0" Background="{StaticResource Surface0Brush}"
                    CornerRadius="8,8,0,0" BorderThickness="0,0,0,1"
                    BorderBrush="{StaticResource Border1Brush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <!-- Window controls (right) -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <Button Content="&#x2500;" Style="{StaticResource TitleBarBtn}"
                                Click="MinimizeButton_Click" ToolTip="Minimize" />
                        <Button x:Name="MaximizeBtn" Content="&#x25A1;" Style="{StaticResource TitleBarBtn}"
                                Click="MaximizeButton_Click" ToolTip="Maximize" />
                        <Button Content="&#x2715;" Style="{StaticResource TitleBarCloseBtn}"
                                Click="CloseButton_Click" ToolTip="Close" />
                    </StackPanel>

                    <!-- App identity (left) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <!-- Logo mark: a stylized terminal prompt -->
                        <Border Width="20" Height="20" CornerRadius="4"
                                Background="{StaticResource AccentSubtleBrush}" Margin="0,0,10,0">
                            <TextBlock Text="&#x276F;" FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="PhoneShell" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource Text1Brush}" VerticalAlignment="Center"
                                   FontFamily="{StaticResource DisplayFont}" />
                        <TextBlock Text="v0.0.8" FontSize="10" Foreground="{StaticResource Text3Brush}"
                                   VerticalAlignment="Center" Margin="8,1,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ============================================ -->
            <!-- MAIN CONTENT AREA                            -->
            <!-- ============================================ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="320" MinWidth="260" MaxWidth="440" />
                    <ColumnDefinition Width="Auto" /> <!-- Splitter -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR -->
                <Border Grid.Column="0" Background="{StaticResource Surface1Brush}"
                        BorderThickness="0,0,1,0" BorderBrush="{StaticResource Border1Brush}">
                    <DockPanel LastChildFill="True">

                        <!-- ===== Language ===== -->
                        <Expander x:Name="LanguageExpander" DockPanel.Dock="Top" Header="Language / 语言"
                                  Style="{StaticResource SidebarExpander}" IsExpanded="False"
                                  Expanded="SidebarExpander_Expanded">
                            <StackPanel>
                                <TextBlock Text="INTERFACE LANGUAGE" Style="{StaticResource SectionLabel}" />
                                <RadioButton x:Name="LangEnRadio" Content="English"
                                             GroupName="Language" Margin="0,0,0,6"
                                             Foreground="{StaticResource Text2Brush}"
                                             FontFamily="{StaticResource BodyFont}" FontSize="12"
                                             Cursor="Hand"
                                             Checked="LanguageRadio_Checked" />
                                <RadioButton x:Name="LangZhRadio" Content="中文"
                                             GroupName="Language" IsChecked="True" Margin="0,0,0,8"
                                             Foreground="{StaticResource Text2Brush}"
                                             FontFamily="{StaticResource BodyFont}" FontSize="12"
                                             Cursor="Hand"
                                             Checked="LanguageRadio_Checked" />
                                <TextBlock Text="Changes apply immediately."
                                           FontSize="10" Foreground="{StaticResource Text3Brush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Expander>

                        <!-- ===== Server Settings ===== -->
                        <Expander x:Name="ServerSettingsExpander" DockPanel.Dock="Top" Header="Server Settings"
                                  Style="{StaticResource SidebarExpander}" IsExpanded="False"
                                  Expanded="SidebarExpander_Expanded">
                            <StackPanel>
                                <CheckBox x:Name="AutoModeCheckBox"
                                          Content="Auto Mode (choose server/client)"
                                          IsChecked="{Binding IsAutoMode}"
                                          Style="{StaticResource DarkCheckBox}" Margin="0,0,0,8" />

                                <CheckBox x:Name="EnableRelayServerCheckBox"
                                          Content="Enable Relay Server (this PC as hub)"
                                          IsChecked="{Binding IsRelayServer}"
                                          IsEnabled="{Binding IsAutoMode, Converter={StaticResource InvertBoolConverter}}"
                                          Style="{StaticResource DarkCheckBox}" Margin="0,0,0,10" />

                                <TextBlock x:Name="ServerPortLabel" Text="PORT" Style="{StaticResource SectionLabel}" />
                                <TextBox Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}"
                                         Width="100" HorizontalAlignment="Left" Margin="0,0,0,10" />

                                <TextBlock x:Name="RelayServerAddressLabel" Text="RELAY SERVER ADDRESS" Style="{StaticResource SectionLabel}" />
                                <TextBox Text="{Binding RelayServerAddress, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,12"
                                         IsEnabled="{Binding IsRelayServer, Converter={StaticResource InvertBoolConverter}}" />

                                <TextBlock x:Name="RelayReachableLabel" Text="LAN LISTEN ADDRESSES" Style="{StaticResource SectionLabel}" />
                                <TextBox Text="{Binding RelayReachableAddresses, Mode=OneWay}"
                                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,4"
                                         IsReadOnly="True" AcceptsReturn="True"
                                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                         Height="64" />
                                <TextBlock x:Name="RelayReachableHintText"
                                           Text="Use these addresses for phones on the same LAN"
                                           FontSize="10" Foreground="{StaticResource Text3Brush}"
                                           TextWrapping="Wrap" Margin="0,0,0,12" />

                                <TextBlock x:Name="GroupSecretLabel" Text="GROUP SECRET" Style="{StaticResource SectionLabel}" />
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding GroupSecret, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DarkTextBox}"
                                             FontFamily="{StaticResource MonoFont}" FontSize="10.5" />
                                    <Button x:Name="GroupSecretCopyButton" Grid.Column="2" Content="Copy" Style="{StaticResource GhostButton}"
                                            Width="58" Height="26"
                                            Command="{Binding CopyGroupSecretCommand}" />
                                </Grid>
                                <TextBlock x:Name="GroupSecretHintText" Text="Share this key with other PCs to join the group"
                                           FontSize="10" Foreground="{StaticResource Text3Brush}"
                                           TextWrapping="Wrap" Margin="0,0,0,12" />

                                <TextBlock x:Name="GroupIdLabel" Text="GROUP ID" Style="{StaticResource SectionLabel}"
                                           Visibility="{Binding IsGroupJoined, Converter={StaticResource BoolToVisConverter}}" />
                                <Grid Margin="0,0,0,12"
                                      Visibility="{Binding IsGroupJoined, Converter={StaticResource BoolToVisConverter}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{Binding GroupId, Mode=OneWay}"
                                             Style="{StaticResource DarkTextBox}"
                                             FontFamily="{StaticResource MonoFont}" FontSize="10.5"
                                             IsReadOnly="True" />
                                    <Button x:Name="GroupIdCopyButton" Grid.Column="2" Content="Copy" Style="{StaticResource GhostButton}"
                                            Width="58" Height="26"
                                            Command="{Binding CopyGroupIdCommand}" />
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Button x:Name="ServerSettingsSaveButton" Content="Save" Style="{StaticResource GhostButton}"
                                            Width="70" Margin="0,0,6,0"
                                            Command="{Binding SaveServerSettingsCommand}" />
                                    <Button x:Name="ServerSettingsStartButton" Content="Start" Style="{StaticResource AccentButton}"
                                            Width="70" Margin="0,0,6,0"
                                            Command="{Binding StartNetworkCommand}"
                                            IsEnabled="{Binding IsServerStopped}" />
                                    <Button x:Name="ServerSettingsStopButton" Content="Stop" Style="{StaticResource DangerButton}"
                                            Width="70"
                                            Command="{Binding StopNetworkCommand}"
                                            IsEnabled="{Binding IsServerRunning}" />
                                </StackPanel>

                                <TextBlock Text="{Binding ServerStatus}" FontSize="11"
                                           Foreground="{StaticResource Text3Brush}" TextWrapping="Wrap" />

                                <!-- Group status -->
                                <TextBlock Text="{Binding GroupStatus}" FontSize="11"
                                           Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           Visibility="{Binding IsGroupJoined, Converter={StaticResource BoolToVisConverter}}" />

                                <!-- Group member list -->
                                <ItemsControl ItemsSource="{Binding GroupMembers}" Margin="0,6,0,0"
                                              Visibility="{Binding IsGroupJoined, Converter={StaticResource BoolToVisConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="6,3" Margin="0,1" CornerRadius="4"
                                                    Background="{StaticResource Surface3Brush}">
                                                <DockPanel>
                                                    <Ellipse DockPanel.Dock="Left" Width="6" Height="6"
                                                             VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="{StaticResource Text3Brush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                        <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Role}"
                                                               FontSize="9" Foreground="{StaticResource Text3Brush}"
                                                               VerticalAlignment="Center"
                                                               FontFamily="{StaticResource MonoFont}" />
                                                    <TextBlock Text="{Binding DisplayName}" FontSize="11"
                                                               Foreground="{StaticResource Text2Brush}"
                                                               VerticalAlignment="Center"
                                                               FontFamily="{StaticResource BodyFont}" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Expander>

                        <!-- ===== Shell Selector ===== -->
                        <Expander x:Name="ShellExpander" DockPanel.Dock="Top" Header="Shell"
                                  Style="{StaticResource SidebarExpander}" IsExpanded="False"
                                  Expanded="SidebarExpander_Expanded">
                            <StackPanel>
                                <TextBlock Text="TERMINAL SHELL" Style="{StaticResource SectionLabel}" />
                                <ComboBox ItemsSource="{Binding AvailableShells}"
                                          SelectedItem="{Binding SelectedShell}"
                                          DisplayMemberPath="DisplayName"
                                          Style="{StaticResource DarkComboBox}" Margin="0,0,0,8" />
                                <Button Content="Refresh" Style="{StaticResource GhostButton}"
                                        Width="80" HorizontalAlignment="Left" Margin="0,0,0,6"
                                        Command="{Binding RefreshShellsCommand}" />
                                <TextBlock Text="Select a shell type, then use [+] or the welcome screen to open sessions."
                                           FontSize="10.5" Foreground="{StaticResource Text3Brush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Expander>

                        <!-- ===== Device Info ===== -->
                        <Expander x:Name="DeviceInfoExpander" DockPanel.Dock="Top" Header="Device Info"
                                  Style="{StaticResource SidebarExpander}" IsExpanded="False"
                                  Expanded="SidebarExpander_Expanded">
                            <StackPanel>
                                <TextBlock Text="DEVICE ID" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding DeviceId}" Foreground="{StaticResource Text2Brush}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,0,0,10" />

                                <TextBlock Text="STATUS" Style="{StaticResource SectionLabel}" />
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Ellipse Style="{StaticResource StatusDot}" x:Name="StatusDot" />
                                    <TextBlock Text="{Binding ConnectionStatus}" Foreground="{StaticResource Text2Brush}"
                                               FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>

                                <TextBlock Text="CONTROL" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding ControlOwnerText}" Foreground="{StaticResource Text2Brush}"
                                           FontSize="12" Margin="0,0,0,8" />

                                <TextBlock Text="SESSION" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding SessionStatus}" Foreground="{StaticResource Text2Brush}"
                                           FontSize="12" TextWrapping="Wrap" />
                            </StackPanel>
                        </Expander>

                        <!-- ===== Group Devices ===== -->
                        <Expander x:Name="GroupDevicesExpander" DockPanel.Dock="Top" Header="Group Devices"
                                  Style="{StaticResource SidebarExpander}" IsExpanded="False"
                                  Expanded="SidebarExpander_Expanded"
                                  Visibility="{Binding IsGroupJoined, Converter={StaticResource BoolToVisConverter}}">
                            <ItemsControl ItemsSource="{Binding GroupMembers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Margin="0,2" CornerRadius="6"
                                                Background="{StaticResource Surface3Brush}">
                                            <StackPanel>
                                                <DockPanel>
                                                    <Ellipse Width="6" Height="6" Margin="0,0,6,0"
                                                             VerticalAlignment="Center" DockPanel.Dock="Left">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#555555" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                        <Setter Property="Fill" Value="#00D4AA" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding Os}" DockPanel.Dock="Right"
                                                               Foreground="{StaticResource Text3Brush}" FontSize="10"
                                                               VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               Foreground="{StaticResource Text1Brush}" FontSize="12"
                                                               FontWeight="Medium" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                                <ItemsControl ItemsSource="{Binding AvailableShells}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding}" Style="{StaticResource GhostButton}"
                                                                    FontSize="10" Padding="6,2" Margin="0,0,4,2"
                                                                    Click="RemoteShellButton_Click"
                                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Border}}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>

                        <!-- ===== QR Code ===== -->
                        <Expander x:Name="QrCodeExpander" DockPanel.Dock="Top" Header="QR Code"
                                  Style="{StaticResource SidebarExpander}" IsExpanded="False"
                                  Expanded="SidebarExpander_Expanded">
                            <StackPanel>
                                <Border Background="{StaticResource Surface0Brush}"
                                        CornerRadius="8" Padding="12" HorizontalAlignment="Left"
                                        BorderBrush="{StaticResource Border2Brush}" BorderThickness="1"
                                        Margin="0,0,0,10">
                                    <Image Source="{Binding QrImage}" Width="180" Height="180" Stretch="Uniform" />
                                </Border>
                                <TextBlock Text="PAYLOAD" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding QrPayload}" FontSize="10.5"
                                           FontFamily="{StaticResource MonoFont}"
                                           Foreground="{StaticResource Text3Brush}"
                                           TextWrapping="Wrap" Margin="0,0,0,10" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Refresh QR" Style="{StaticResource GhostButton}"
                                            Width="100" Margin="0,0,6,0"
                                            Command="{Binding RefreshQrCommand}" />
                                    <Button Content="Disconnect" Style="{StaticResource DangerButton}"
                                            Width="100"
                                            Command="{Binding ForceDisconnectCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- ===== AI Settings ===== -->
                        <Expander x:Name="AiSettingsExpander" DockPanel.Dock="Top" Header="AI Settings"
                                  Style="{StaticResource SidebarExpander}" IsExpanded="True"
                                  Expanded="SidebarExpander_Expanded">
                            <StackPanel>
                                <TextBlock Text="API ENDPOINT" Style="{StaticResource SectionLabel}" />
                                <TextBox Text="{Binding AiEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,10" />

                                <TextBlock Text="API KEY" Style="{StaticResource SectionLabel}" />
                                <PasswordBox x:Name="ApiKeyBox" PasswordChanged="ApiKeyBox_PasswordChanged"
                                             Style="{StaticResource DarkPasswordBox}" Margin="0,0,0,10" />

                                <TextBlock Text="MODEL" Style="{StaticResource SectionLabel}" />
                                <TextBox Text="{Binding AiModelName, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DarkTextBox}" Margin="0,0,0,10" />

                                <Button Content="Save" Style="{StaticResource AccentButton}"
                                        Width="80" HorizontalAlignment="Left"
                                        Command="{Binding SaveAiSettingsCommand}" />
                            </StackPanel>
                        </Expander>

                        <!-- ===== Debug Log ===== -->
                        <Expander x:Name="DebugLogExpander" DockPanel.Dock="Top" Header="Debug Log"
                                  Style="{StaticResource SidebarExpander}" IsExpanded="False"
                                  Expanded="SidebarExpander_Expanded">
                            <ListBox ItemsSource="{Binding DebugLogs}" MaxHeight="300"
                                     BorderThickness="0" Background="Transparent"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0,1" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Mode=OneWay}" IsReadOnly="True"
                                                 Background="{StaticResource Surface0Brush}"
                                                 Foreground="{StaticResource Text3Brush}"
                                                 BorderThickness="1" BorderBrush="{StaticResource Border1Brush}"
                                                 Padding="6,4" FontSize="10"
                                                 FontFamily="{StaticResource MonoFont}"
                                                 TextWrapping="NoWrap" Margin="0,1"
                                                 MaxHeight="200"
                                                 VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Expander>

                        <!-- ===== AI CHAT (fills remaining space) ===== -->
                        <DockPanel Margin="0">
                            <!-- Chat header -->
                            <Border DockPanel.Dock="Top" Padding="14,10"
                                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource Border1Brush}">
                                <TextBlock Text="AI CHAT" FontSize="11.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource Text3Brush}"
                                           FontFamily="{StaticResource BodyFont}" />
                            </Border>

                            <!-- Input area at bottom -->
                            <Border DockPanel.Dock="Bottom" Padding="10,8"
                                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource Border1Brush}"
                                    Background="{StaticResource Surface2Brush}">
                                <DockPanel>
                                    <!-- Status panel above input -->
                                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                        <!-- Auto-exec status -->
                                        <DockPanel Visibility="{Binding IsAutoExecuting, Converter={StaticResource BoolToVisConverter}}">
                                            <Button DockPanel.Dock="Right" Content="Stop"
                                                    Style="{StaticResource DangerButton}"
                                                    Padding="10,4" FontSize="11"
                                                    Command="{Binding StopAutoExecCommand}" Margin="6,0,0,0" />
                                            <TextBlock Text="{Binding AutoExecStatus}"
                                                       FontSize="11" Foreground="{StaticResource DangerBrush}"
                                                       VerticalAlignment="Center" />
                                        </DockPanel>
                                        <!-- AI thinking -->
                                        <TextBlock Text="AI is thinking..."
                                                   FontSize="11" Foreground="{StaticResource Text3Brush}"
                                                   Visibility="{Binding IsAiLoading, Converter={StaticResource BoolToVisConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAutoExecuting}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Input row -->
                                    <Button DockPanel.Dock="Right" Content="&#x27A4;"
                                            Style="{StaticResource AccentButton}"
                                            Width="38" FontSize="14" Padding="0,6"
                                            Command="{Binding SendMessageCommand}"
                                            IsEnabled="{Binding IsNotAutoExecuting}"
                                            Margin="6,0,0,0" />
                                    <TextBox x:Name="ChatInputBox"
                                             Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="ChatInput_KeyDown"
                                             IsEnabled="{Binding IsNotAutoExecuting}"
                                             Style="{StaticResource DarkTextBox}"
                                             FontSize="12" Padding="10,8" />
                                </DockPanel>
                            </Border>

                            <!-- Chat messages list -->
                            <ListBox x:Name="ChatListBox" ItemsSource="{Binding ChatMessages}"
                                     Style="{StaticResource ChatListBox}"
                                     Background="{StaticResource Surface1Brush}"
                                     Padding="6,4">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0,2" />
                                        <Setter Property="Focusable" Value="False" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" CornerRadius="8" Margin="4,2" MaxWidth="280">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <!-- AI message: dark surface -->
                                                    <Setter Property="Background" Value="{StaticResource Surface3Brush}" />
                                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                                    <Style.Triggers>
                                                        <!-- User message: accent tint -->
                                                        <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}" />
                                                            <Setter Property="HorizontalAlignment" Value="Right" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                       FontSize="12" Foreground="{StaticResource Text1Brush}"
                                                       FontFamily="{StaticResource BodyFont}" />
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </DockPanel>
                </Border>

                <!-- GRID SPLITTER -->
                <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="{StaticResource Border1Brush}"
                              Cursor="SizeWE" />

                <!-- RIGHT PANEL: Terminal -->
                <Border Grid.Column="2" Background="{StaticResource Surface0Brush}">
                    <Grid>
                        <!-- Welcome Screen -->
                        <StackPanel x:Name="WelcomePanel" VerticalAlignment="Center"
                                    HorizontalAlignment="Center" Visibility="Visible">

                            <!-- Hero icon -->
                            <Border Width="64" Height="64" CornerRadius="16"
                                    Background="{StaticResource AccentSubtleBrush}"
                                    HorizontalAlignment="Center" Margin="0,0,0,20">
                                <TextBlock Text="&#x276F;_" FontSize="26" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontFamily="{StaticResource MonoFont}" />
                            </Border>

                            <TextBlock Text="Welcome to PhoneShell" FontSize="26" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" Foreground="{StaticResource Text1Brush}"
                                       Margin="0,0,0,8" FontFamily="{StaticResource DisplayFont}" />
                            <TextBlock Text="Select a shell type and create a new session to get started."
                                       FontSize="13" Foreground="{StaticResource Text3Brush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,32"
                                       TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420"
                                       FontFamily="{StaticResource BodyFont}" />

                            <!-- Shell type cards -->
                            <ItemsControl x:Name="ShellCardsPanel" ItemsSource="{Binding AvailableShells}"
                                          HorizontalAlignment="Center" Margin="0,0,0,28">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="8" Padding="20,14" Margin="5"
                                                BorderBrush="{StaticResource Border2Brush}" BorderThickness="1"
                                                Background="{StaticResource Surface2Brush}"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ShellCard_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource Surface4Brush}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                                           FontSize="13.5" Foreground="{StaticResource Text1Brush}"
                                                           HorizontalAlignment="Center"
                                                           FontFamily="{StaticResource BodyFont}" />
                                                <TextBlock Text="{Binding Id}" FontSize="10"
                                                           Foreground="{StaticResource Text3Brush}"
                                                           HorizontalAlignment="Center" Margin="0,3,0,0"
                                                           FontFamily="{StaticResource MonoFont}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- New Session button -->
                            <Button x:Name="WelcomeNewSessionButton" Content="+ New Session" FontSize="14" Padding="24,11"
                                    HorizontalAlignment="Center"
                                    Style="{StaticResource AccentButton}"
                                    FontFamily="{StaticResource BodyFont}"
                                    Command="{Binding NewSessionCommand}" />
                        </StackPanel>

                        <!-- Tab Container -->
                        <DockPanel x:Name="TabContainer" Visibility="Collapsed">
                            <!-- Tab Bar -->
                            <Border DockPanel.Dock="Top" Background="{StaticResource Surface2Brush}"
                                    Padding="6,4,6,0"
                                    BorderThickness="0,0,0,1" BorderBrush="{StaticResource Border1Brush}">
                                <DockPanel>
                                    <!-- Right controls -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="8,0,0,0">

                                        <!-- New tab -->
                                        <Button x:Name="NewTabButton" Content="+" FontSize="16" FontWeight="Bold"
                                                Style="{StaticResource SubtleButton}"
                                                Width="30" Height="26" Padding="0"
                                                Command="{Binding NewSessionCommand}"
                                                ToolTip="New Session" />

                                        <!-- Compact mode toggle -->
                                        <Button x:Name="CompactModeButton" Content="Compact"
                                                Style="{StaticResource GhostButton}"
                                                FontSize="11" Padding="10,4" Margin="4,0,0,0"
                                                Click="CompactModeButton_Click"
                                                ToolTip="Toggle compact (mobile) size" />

                                        <!-- Close session -->
                                        <Button Content="Close" Style="{StaticResource DangerButton}"
                                                FontSize="11" Padding="10,4" Margin="4,0,0,0"
                                                Click="TitleBarCloseButton_Click"
                                                ToolTip="Close this session" />
                                    </StackPanel>

                                    <!-- Tab items -->
                                    <ItemsControl x:Name="TabBar" ItemsSource="{Binding Tabs}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="TabItemBorder" Padding="12,6,6,6"
                                                        Margin="0,0,2,0" CornerRadius="6,6,0,0"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="TabItem_Click"
                                                        Background="{StaticResource Surface3Brush}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource Surface4Brush}" />
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Background" Value="#1A3A5C" />
                                                                    <Setter Property="BorderBrush" Value="#2A5A8C" />
                                                                    <Setter Property="BorderThickness" Value="1,1,1,0" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <!-- Small colored indicator -->
                                                        <Ellipse Width="6" Height="6"
                                                                 VerticalAlignment="Center" Margin="0,0,7,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Setter Property="Fill" Value="{StaticResource Text3Brush}" />
                                                                    <Setter Property="Opacity" Value="0.5" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                            <Setter Property="Fill" Value="#4DA6FF" />
                                                                            <Setter Property="Opacity" Value="1" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <!-- Remote terminal indicator -->
                                                        <TextBlock Text="&#x2B21;" FontSize="8" VerticalAlignment="Center" Margin="0,0,4,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#FF9800" />
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRemote}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Title}" FontSize="12"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                                   FontFamily="{StaticResource BodyFont}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource Text3Brush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
                                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Button Content="&#x2715;" FontSize="9"
                                                                Width="18" Height="18"
                                                                Style="{StaticResource SubtleButton}"
                                                                Padding="0" Cursor="Hand"
                                                                Click="TabCloseButton_Click"
                                                                Tag="{Binding TabId}"
                                                                VerticalAlignment="Center"
                                                                ToolTip="Close Tab" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>
                            </Border>

                            <!-- Terminal WebView -->
                            <wv2:WebView2 x:Name="TerminalWebView" />
                        </DockPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============================================ -->
            <!-- STATUS BAR                                   -->
            <!-- ============================================ -->
            <Border Grid.Row="2" Background="{StaticResource Surface0Brush}"
                    CornerRadius="0,0,8,8" Padding="14,0"
                    BorderThickness="0,1,0,0" BorderBrush="{StaticResource Border1Brush}">
                <DockPanel VerticalAlignment="Center">
                    <!-- Right side indicators -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                        <TextBlock Text="{Binding SessionStatus}" FontSize="10.5"
                                   Foreground="{StaticResource Text3Brush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   VerticalAlignment="Center" Margin="0,0,16,0" />
                        <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,5,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource Text3Brush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="10.5" VerticalAlignment="Center"
                                   FontFamily="{StaticResource MonoFont}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="offline" />
                                    <Setter Property="Foreground" Value="{StaticResource Text3Brush}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsServerRunning}" Value="True">
                                            <Setter Property="Text" Value="online" />
                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Left side branding -->
                    <TextBlock Text="PhoneShell  --  Remote Terminal Control"
                               FontSize="10.5" Foreground="{StaticResource Text3Brush}"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource MonoFont}" />
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
