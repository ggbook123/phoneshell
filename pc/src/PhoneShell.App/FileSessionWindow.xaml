<Window x:Class="PhoneShell.FileSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Session" Height="760" Width="980"
        MinWidth="680" MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface1Brush}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource Surface2Brush}"
                BorderBrush="{StaticResource Border1Brush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10"
                Margin="0,0,0,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                    <Button x:Name="ReloadButton"
                            Content="刷新"
                            Style="{StaticResource GhostButton}"
                            Padding="10,4"
                            Margin="0,0,6,0"
                            Click="ReloadButton_Click" />
                    <Button x:Name="InsertPathButton"
                            Content="插入路径到当前会话"
                            Style="{StaticResource AccentButton}"
                            Padding="12,4"
                            Click="InsertPathButton_Click" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="文件路径"
                               Foreground="{StaticResource Text3Brush}"
                               FontSize="10.5" />
                    <TextBox x:Name="FilePathText"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             Background="{StaticResource Surface0Brush}"
                             Foreground="{StaticResource Text2Brush}"
                             BorderBrush="{StaticResource Border1Brush}"
                             BorderThickness="1"
                             FontFamily="{StaticResource MonoFont}"
                             FontSize="11"
                             Padding="8,6" />
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBox x:Name="FileContentText"
                 Grid.Row="1"
                 TextWrapping="NoWrap"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 HorizontalScrollBarVisibility="Auto"
                 VerticalScrollBarVisibility="Auto"
                 IsReadOnly="True"
                 FontFamily="{StaticResource MonoFont}"
                 FontSize="12"
                 Style="{StaticResource DarkTextBox}" />
    </Grid>
</Window>
