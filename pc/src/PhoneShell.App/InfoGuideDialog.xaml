<Window x:Class="PhoneShell.InfoGuideDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作说明"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        Width="560"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        Background="{StaticResource Surface1Brush}"
        FontFamily="{StaticResource BodyFont}">
    <Border Background="{StaticResource Surface2Brush}"
            BorderBrush="{StaticResource Border2Brush}"
            BorderThickness="1"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource Surface0Brush}"
                    BorderBrush="{StaticResource Border1Brush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left"
                               Text="操作说明"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Text1Brush}"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource DisplayFont}" />
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,18,20,12">
                <TextBlock Text="1. 在连接设置点击启动按钮"
                           FontSize="12.5"
                           Foreground="{StaticResource Text1Brush}" />
                <TextBlock Text="2. 手机扫码连接"
                           Margin="0,8,0,0"
                           FontSize="12.5"
                           Foreground="{StaticResource Text1Brush}" />

                <Border Margin="0,14,0,0"
                        Padding="12,10"
                        Background="{StaticResource Surface0Brush}"
                        BorderBrush="{StaticResource Border1Brush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="github 地址"
                                   FontSize="10.5"
                                   Foreground="{StaticResource Text3Brush}" />
                        <TextBlock Text="https://github.com/ggbook123/phoneshell"
                                   Margin="0,4,0,0"
                                   FontSize="11.5"
                                   Foreground="{StaticResource Text2Brush}"
                                   FontFamily="{StaticResource MonoFont}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Text="请署名原项目地址"
                           Margin="0,12,0,0"
                           FontSize="11.5"
                           Foreground="{StaticResource Text2Brush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="本软件为开源软件，仅供学习、交流，请勿用于商业化，原作者拥有最终解释权。"
                           Margin="0,8,0,0"
                           FontSize="11.5"
                           Foreground="{StaticResource Text2Brush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="版本号 v1.0.0"
                           Margin="0,12,0,0"
                           FontSize="11"
                           Foreground="{StaticResource Text3Brush}" />
            </StackPanel>

            <Border Grid.Row="2"
                    Background="{StaticResource Surface1Brush}"
                    BorderBrush="{StaticResource Border1Brush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="知道了"
                            Width="90"
                            Height="30"
                            Style="{StaticResource AccentButton}"
                            IsDefault="True"
                            IsCancel="True" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
