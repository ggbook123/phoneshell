<Window x:Class="PhoneShell.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource BodyFont}">
    <Border Background="{StaticResource Surface1Brush}"
            BorderBrush="{StaticResource Border2Brush}"
            BorderThickness="1"
            CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22"
                              ShadowDepth="0"
                              Opacity="0.35"
                              Color="#000000" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
                <RowDefinition Height="58" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource Surface0Brush}"
                    BorderBrush="{StaticResource Border1Brush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    Padding="16,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <DockPanel LastChildFill="True">
                    <TextBlock x:Name="HeaderTextBlock"
                               Text="Confirm"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Text1Brush}"
                               VerticalAlignment="Center"
                               FontFamily="{StaticResource DisplayFont}" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="1"
                  Margin="18,18,18,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="34"
                        Height="34"
                        CornerRadius="17"
                        Background="{StaticResource AccentSubtleBrush}"
                        VerticalAlignment="Top">
                    <TextBlock Text="?"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="MessageTextBlock"
                               Text="Message"
                               FontSize="12.5"
                               Foreground="{StaticResource Text1Brush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource Surface2Brush}"
                    BorderBrush="{StaticResource Border1Brush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8"
                    Padding="16,0">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Width="92"
                            Height="30"
                            Margin="0,0,8,0"
                            Style="{StaticResource GhostButton}"
                            IsCancel="True"
                            Click="CancelButton_Click" />
                    <Button x:Name="AlternateButton"
                            Content="Alternate"
                            Width="92"
                            Height="30"
                            Margin="0,0,8,0"
                            Style="{StaticResource GhostButton}"
                            Visibility="Collapsed"
                            Click="AlternateButton_Click" />
                    <Button x:Name="ConfirmButton"
                            Content="Confirm"
                            Width="92"
                            Height="30"
                            Style="{StaticResource AccentButton}"
                            IsDefault="True"
                            Click="ConfirmButton_Click" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
