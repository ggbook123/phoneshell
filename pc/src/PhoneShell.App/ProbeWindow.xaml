<Window x:Class="PhoneShell.ProbeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PhoneShell.ViewModels"
        xmlns:utils="clr-namespace:PhoneShell.Utilities"
        Title="Device Probe"
        Width="1200"
        Height="860"
        MinWidth="820"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface0Brush}"
        FontFamily="{StaticResource BodyFont}"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <utils:PercentToWidthConverter x:Key="PercentToWidthConverter" />

        <LinearGradientBrush x:Key="ProbeHeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F011171F" Offset="0" />
            <GradientStop Color="#F0152028" Offset="0.52" />
            <GradientStop Color="#F00E181D" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="ProbePanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#D9141A22" />
            <Setter Property="BorderBrush" Value="{StaticResource Border2Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="24" />
        </Style>

        <Style x:Key="ProbeSectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10.5" />
            <Setter Property="Foreground" Value="{StaticResource Text3Brush}" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        </Style>

        <Style x:Key="MetricCardBorder" TargetType="Border" BasedOn="{StaticResource ProbePanelBorder}">
            <Setter Property="Margin" Value="8" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="MinHeight" Value="270" />
        </Style>

        <Style x:Key="DetailCardBorder" TargetType="Border" BasedOn="{StaticResource ProbePanelBorder}">
            <Setter Property="Margin" Value="8" />
            <Setter Property="Padding" Value="18" />
        </Style>

        <Style x:Key="DetailRowBorder" TargetType="Border">
            <Setter Property="Background" Value="#B8151A22" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="SnapshotVisibleGrid" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSnapshot}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EmptyStateBorderStyle" TargetType="Border" BasedOn="{StaticResource ProbePanelBorder}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSnapshot}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailItemsControlStyle" TargetType="ItemsControl">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasItems}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DetailEmptyTextStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Foreground" Value="{StaticResource Text3Brush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasItems}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SortToggleHostStyle" TargetType="StackPanel">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowSortToggle}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SortToggleButtonBase" TargetType="Button">
            <Setter Property="MinWidth" Value="56" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="#8C121A22" />
            <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border1Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="999"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentDimBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource Text1Brush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimarySortButtonStyle" TargetType="Button" BasedOn="{StaticResource SortToggleButtonBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPrimarySortSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondarySortButtonStyle" TargetType="Button" BasedOn="{StaticResource SortToggleButtonBase}">
            <Setter Property="Margin" Value="0" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSecondarySortSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSubtleBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentDimBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="{StaticResource Surface0Color}" />
        </Grid.Background>

        <Ellipse Width="500" Height="500" Fill="{StaticResource AccentBrush}" Opacity="0.05"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-200,-140,0" />
        <Ellipse Width="380" Height="380" Fill="{StaticResource InfoBrush}" Opacity="0.06"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-120,0,0,-150" />

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" CanContentScroll="False">
            <Grid MaxWidth="1320" Margin="20,14,20,20" HorizontalAlignment="Center">
                <Border Style="{StaticResource ProbePanelBorder}" Background="{StaticResource ProbeHeroBrush}" Padding="8">
                    <Grid>
                        <Grid Style="{StaticResource SnapshotVisibleGrid}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ItemsControl Grid.Row="0" ItemsSource="{Binding MetricCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ProbeMetricCardViewModel}">
                                        <Border Style="{StaticResource MetricCardBorder}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Ellipse Grid.Column="1" Width="132" Height="132" Margin="0,-20,-24,0"
                                                         HorizontalAlignment="Right" VerticalAlignment="Top"
                                                         Fill="{Binding AccentBrush}" Opacity="0.06" />

                                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                                    <DockPanel LastChildFill="False">
                                                        <TextBlock Text="{Binding Title}" FontSize="13.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Text1Brush}" />
                                                        <Border DockPanel.Dock="Right" Background="{Binding AccentSurfaceBrush}"
                                                                CornerRadius="999" Padding="10,4">
                                                            <TextBlock Text="{Binding Glyph}" FontSize="10.5"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       Foreground="{Binding AccentBrush}" />
                                                        </Border>
                                                    </DockPanel>

                                                    <TextBlock Margin="0,14,0,0" Text="{Binding ValueText}" FontSize="21"
                                                               FontWeight="SemiBold" Foreground="{StaticResource Text1Brush}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,6,0,0" Text="{Binding CaptionText}" Style="{StaticResource ProbeSectionLabel}" />
                                                    <TextBlock Margin="0,10,0,0" Text="{Binding DetailText}" FontSize="12.5"
                                                               Foreground="{StaticResource Text2Brush}" TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Grid Grid.Column="1" Width="106" Height="106" HorizontalAlignment="Right">
                                                    <Ellipse Stroke="{StaticResource Border1Brush}" StrokeThickness="10" />
                                                    <Path Data="{Binding RingGeometry}" Stroke="{Binding AccentBrush}" StrokeThickness="10"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CenterValueText}" HorizontalAlignment="Center" FontSize="22"
                                                                   FontWeight="SemiBold" Foreground="{StaticResource Text1Brush}" />
                                                        <TextBlock Text="%" HorizontalAlignment="Center" Margin="0,-3,0,0" FontSize="11"
                                                                   Foreground="{StaticResource Text3Brush}" FontFamily="{StaticResource MonoFont}" />
                                                    </StackPanel>
                                                </Grid>

                                                <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,16,0,0"
                                                        Background="{StaticResource Surface0Brush}" BorderBrush="{StaticResource Border1Brush}"
                                                        BorderThickness="1" CornerRadius="14" Padding="12,10">
                                                    <StackPanel>
                                                        <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                                            <TextBlock Text="TREND" Style="{StaticResource ProbeSectionLabel}" />
                                                            <Border DockPanel.Dock="Right" Background="{Binding AccentSurfaceBrush}"
                                                                    CornerRadius="999" Padding="9,4">
                                                                <TextBlock Text="{Binding ScoreText}" FontSize="10.5"
                                                                           FontFamily="{StaticResource MonoFont}"
                                                                           Foreground="{Binding AccentBrush}" />
                                                            </Border>
                                                        </DockPanel>
                                                        <Grid Height="44">
                                                            <Rectangle Height="1" VerticalAlignment="Center" RadiusX="999" RadiusY="999"
                                                                       Fill="{StaticResource Border1Brush}" Opacity="0.35" />
                                                            <Path Data="{Binding TrendGeometry}" Stroke="{Binding AccentBrush}"
                                                                  StrokeThickness="2.4" StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding ProcessDetailCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ProbeProcessDetailCardViewModel}">
                                        <Border Style="{StaticResource DetailCardBorder}">
                                            <StackPanel>
                                                <DockPanel LastChildFill="False">
                                                    <StackPanel Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding Title}" FontSize="14.5" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource Text1Brush}" />
                                                        <TextBlock Margin="0,6,0,0" Text="{Binding Subtitle}" FontSize="12"
                                                                   Foreground="{StaticResource Text2Brush}" TextWrapping="Wrap" />
                                                    </StackPanel>

                                                    <StackPanel DockPanel.Dock="Right"
                                                                Orientation="Horizontal"
                                                                Style="{StaticResource SortToggleHostStyle}">
                                                        <Button Content="{Binding PrimarySortText}"
                                                                Style="{StaticResource PrimarySortButtonStyle}"
                                                                Click="NetworkSortDownloadButton_Click" />
                                                        <Button Content="{Binding SecondarySortText}"
                                                                Style="{StaticResource SecondarySortButtonStyle}"
                                                                Click="NetworkSortUploadButton_Click" />
                                                    </StackPanel>
                                                </DockPanel>

                                                <TextBlock Margin="0,16,0,0" Text="{Binding EmptyText}" Style="{StaticResource DetailEmptyTextStyle}" />

                                                <ItemsControl Margin="0,16,0,0" ItemsSource="{Binding Items}" Style="{StaticResource DetailItemsControlStyle}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ProbeProcessDetailItemViewModel}">
                                                            <Border Style="{StaticResource DetailRowBorder}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Border Width="28" Height="28" CornerRadius="14"
                                                                            Background="{Binding DataContext.AccentSurfaceBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                                                        <TextBlock Text="{Binding Rank}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   FontSize="11" FontWeight="SemiBold"
                                                                                   Foreground="{Binding DataContext.AccentBrush, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                                                    </Border>
                                                                    <StackPanel Grid.Column="1" Margin="10,0,12,0">
                                                                        <TextBlock Text="{Binding ProcessName}" FontSize="12.5" FontWeight="SemiBold"
                                                                                   Foreground="{StaticResource Text1Brush}" TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Margin="0,4,0,0" Text="{Binding MetaText}" FontSize="10.5"
                                                                                   FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource Text3Brush}" />
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding ValueText}" HorizontalAlignment="Right"
                                                                               VerticalAlignment="Center" FontSize="12"
                                                                               FontWeight="SemiBold" Foreground="{StaticResource Text1Brush}"
                                                                               TextWrapping="Wrap" TextAlignment="Right" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>

                        <Border Style="{StaticResource EmptyStateBorderStyle}" Padding="32">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="460" Margin="0,30">
                                <Border Width="74" Height="74" Background="{StaticResource AccentSubtleBrush}"
                                        BorderBrush="{StaticResource AccentDimBrush}" BorderThickness="1"
                                        CornerRadius="37" HorizontalAlignment="Center">
                                    <TextBlock Text="PR" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}"
                                               FontFamily="{StaticResource MonoFont}" />
                                </Border>
                                <TextBlock Margin="0,20,0,0" Text="{Binding EmptyStateTitle}" HorizontalAlignment="Center"
                                           FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource Text1Brush}"
                                           TextAlignment="Center" />
                                <TextBlock Margin="0,10,0,0" Text="{Binding EmptyStateMessage}" HorizontalAlignment="Center"
                                           TextAlignment="Center" FontSize="13" TextWrapping="Wrap"
                                           Foreground="{StaticResource Text2Brush}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
