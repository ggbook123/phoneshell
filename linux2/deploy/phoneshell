#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INSTALL_SH="${SCRIPT_DIR}/install.sh"
PREFIX_DEFAULT="/opt/phoneshell"
CLI_JS="${PREFIX_DEFAULT}/dist/cli.js"

show_help() {
  cat <<EOF
PhoneShell Command

Usage:
  phoneshell install            Run interactive installer (menu)
  phoneshell local [args]        Open local CLI (wraps: node dist/cli.js local)
  phoneshell attach [args]       Attach to existing session
  phoneshell list                List sessions
  phoneshell group reset         Clear group data (group.json + group-membership.json)
  phoneshell status              Show systemd status
  phoneshell start|stop|restart  Control systemd service
  phoneshell logs                Tail service logs
  phoneshell help                Show this help

Installer shortcut:
  sudo bash linux2/deploy/phoneshell install
EOF
}

run_install_menu() {
  local port="19090"
  local web_panel="true"
  local panel_port="9090"

  while true; do
    echo ""
    echo "PhoneShell Installer"
    echo "1) Set core port (current: ${port})"
    echo "2) Enable web panel (current: ${web_panel})"
    echo "3) Set web panel port (current: ${panel_port})"
    echo "4) Install now"
    echo "0) Exit"
    read -r -p "Select [0-4]: " choice
    case "${choice}" in
      1)
        read -r -p "Core port [${port}]: " input
        if [[ -n "${input}" ]]; then port="${input}"; fi
        ;;
      2)
        if [[ "${web_panel}" == "true" ]]; then web_panel="false"; else web_panel="true"; fi
        ;;
      3)
        if [[ "${web_panel}" != "true" ]]; then
          echo "Web panel is disabled. Enable it first."
        else
          read -r -p "Web panel port [${panel_port}]: " input
          if [[ -n "${input}" ]]; then panel_port="${input}"; fi
        fi
        ;;
      4)
        break
        ;;
      0|q|quit)
        exit 0
        ;;
      *)
        echo "Invalid selection."
        ;;
    esac
  done

  bash "${INSTALL_SH}" --non-interactive \
    --port "${port}" \
    --web-panel "${web_panel}" \
    --panel-port "${panel_port}"
}

require_cli() {
  if [[ ! -f "${CLI_JS}" ]]; then
    echo "CLI not found at ${CLI_JS}. Run: sudo bash linux2/deploy/phoneshell install"
    exit 1
  fi
  if ! command -v node >/dev/null 2>&1; then
    echo "Node.js not found. Install Node.js >= 18."
    exit 1
  fi
}

cmd="${1:-}"
shift || true

case "${cmd}" in
  install)
    if [[ $# -gt 0 ]]; then
      bash "${INSTALL_SH}" "$@"
    else
      run_install_menu
    fi
    ;;
  local)
    require_cli
    node "${CLI_JS}" local "$@"
    ;;
  attach)
    require_cli
    node "${CLI_JS}" local --attach "$@"
    ;;
  list)
    require_cli
    node "${CLI_JS}" local --list
    ;;
  group)
    require_cli
    node "${CLI_JS}" group "$@"
    ;;
  status)
    systemctl status phoneshell --no-pager
    ;;
  start|stop|restart)
    systemctl "${cmd}" phoneshell
    ;;
  logs)
    journalctl -u phoneshell -f
    ;;
  help|-h|--help)
    show_help
    ;;
  "")
    require_cli
    node "${CLI_JS}" local
    ;;
  *)
    echo "Unknown command: ${cmd}"
    show_help
    exit 1
    ;;
esac
