{
  "name": "phoneshell-linux2",
  "version": "0.2.0",
  "description": "PhoneShell Linux server — Node.js + TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "psh": "dist/cli.js",
    "phoneshell": "dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "deploy",
    "web/dist",
